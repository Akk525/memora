# ---------------------------------------------------------------------------
# Memora – copy to .env and fill in. Do not commit .env.
# ---------------------------------------------------------------------------

# --- Supabase (you have this) ---
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_from_supabase_settings

# --- Hedera testnet (needed for indexer, key-broker, contracts, CLI) ---
# Create a testnet account: https://portal.hedera.com/register
HEDERA_OPERATOR_ID=0.0.xxxxx
HEDERA_OPERATOR_KEY=your_operator_private_key_hex_or_ed25519_der

# Hedera EVM RPC (testnet default – usually no change)
HEDERA_EVM_RPC_URL=https://testnet.hashio.io/api

# Optional: mainnet
# HEDERA_NETWORK=testnet

# --- Set after creating HCS topic and deploying contract ---
# Create topic: Hedera portal or SDK → set HCS_TOPIC_ID (e.g. 0.0.12345)
HCS_TOPIC_ID=
# After: cd packages/contracts && pnpm run deploy
MEMORA_REGISTRY_CONTRACT_ID=

# --- Local services (used when indexer/key-broker run locally) ---
INDEXER_BASE_URL=http://localhost:3001
KEY_BROKER_BASE_URL=http://localhost:3000

# --- IPFS (Pinata) – needed for indexer to pin encrypted payloads ---
# Create API key: https://app.pinata.cloud/ → API Keys → JWT
PINATA_JWT=your_pinata_jwt

# --- Optional: CLI read/verify (wallet that is owner or delegate of the agent) ---
# PRIVATE_KEY=0x...  # hex private key for signing read challenges

# --- Required for proof:delegate (second EVM wallet; owner = HEDERA_OPERATOR_KEY) ---
# Create a second wallet (e.g. MetaMask test account or: node -e "console.log(require('ethers').Wallet.createRandom().privateKey)")
DELEGATE_PRIVATE_KEY=0x...

# --- Optional overrides ---
# PORT=3000              # key-broker (default 3000)
# PORT=3001              # indexer (default 3001)
# IPFS_GATEWAY_URL=...   # CLI (default Pinata gateway)
